<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane minHeight="-Infinity" minWidth="-Infinity" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.javafx.csit228capstone.screens.queue.QueueFormController">
    <left>
        <fx:include fx:id="menu" source="../menu-pane.fxml" />
    </left>
    <center>
        <VBox fillWidth="true" maxWidth="1.7976931348623157E308" styleClass="main-pane" BorderPane.alignment="CENTER">
            <children>

                <HBox alignment="CENTER" prefHeight="71.0">
                    <children>
                        <Label text="Queue">
                            <font><Font size="24.0" /></font>
                        </Label>
                        <Region maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" />
                        <Pane fx:id="notification" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="33.0" prefWidth="32.0" styleClass="notification-icon" />
                    </children>
                </HBox>

                <VBox alignment="CENTER_LEFT">
                    <children>
                        <HBox alignment="CENTER_LEFT" prefHeight="25.0" styleClass="back-to-queuetype">
                            <children>
                                <Pane prefHeight="34.0" prefWidth="31.0" styleClass="arrow-back" />
                                <Label text="Back to Queue Types" />
                            </children>
                        </HBox>
                        <Label text="General Care Form">
                            <font><Font name="System Bold" size="22.0" /></font>
                        </Label>
                    </children>
                    <VBox.margin><Insets bottom="10.0" top="10.0" /></VBox.margin>
                </VBox>

                <HBox alignment="CENTER_LEFT" styleClass="notice">
                    <children>
                        <Pane prefHeight="37.0" prefWidth="37.0" styleClass="notice-icon" />
                        <Label maxWidth="1.7976931348623157E308" text="For general checkups and basic healthcare needs. Our staff will assess your information and call your queue number when it's your turn." wrapText="true" HBox.hgrow="ALWAYS">
                            <HBox.margin><Insets left="10.0" /></HBox.margin>
                        </Label>
                    </children>
                    <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0" /></padding>
                    <VBox.margin><Insets bottom="10.0" /></VBox.margin>
                </HBox>

                <ScrollPane fx:id="scrollPane" fitToHeight="false" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox maxWidth="1.7976931348623157E308" spacing="16.0" styleClass="form">
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                            <children>

                                <GridPane hgap="10.0" maxWidth="1.7976931348623157E308" vgap="5.0">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
                                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="100.0" minWidth="10.0" prefWidth="80.0" />
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints minHeight="10.0" prefHeight="25.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="25.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="25.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="25.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
                                    </rowConstraints>
                                    <children>
                                        <Label text="First Name" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                        <Label text="M.I" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                        <TextField GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                        <TextField GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                        <Label text="Last Name" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                        <TextField GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="3" />
                                        <Label text="Age" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                                        <TextField maxWidth="80.0" prefWidth="80.0" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                                        <Label text="Gender" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                                        <HBox alignment="CENTER_LEFT" spacing="20.0" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="7">
                                            <children>
                                                <RadioButton mnemonicParsing="false" text="Male" />
                                                <RadioButton mnemonicParsing="false" text="Female" />
                                            </children>
                                        </HBox>
                                    </children>
                                </GridPane>

                                <GridPane hgap="10.0" maxWidth="1.7976931348623157E308" vgap="5.0">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
                                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="100.0" minWidth="10.0" prefWidth="80.0" />
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints minHeight="10.0" prefHeight="25.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="25.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="25.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
                                    </rowConstraints>
                                    <children>
                                        <Label text="Purpose of Visit" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                        <ComboBox maxWidth="1.7976931348623157E308" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="1" />
                                        <Label text="Symptoms" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                        <TextField GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="3" />
                                        <Label text="Patient Type" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                                        <HBox alignment="CENTER_LEFT" spacing="20.0" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="5">
                                            <children>
                                                <RadioButton mnemonicParsing="false" text="Regular" />
                                                <RadioButton mnemonicParsing="false" text="Person with Disability" />
                                                <RadioButton mnemonicParsing="false" text="Senior Citizen" />
                                    <RadioButton layoutX="10.0" layoutY="19.0" mnemonicParsing="false" text="Pregnant" />
                                            </children>
                                        </HBox>
                                    </children>
                                </GridPane>

                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Contact Number" />
                                        <TextField maxWidth="1.7976931348623157E308" />
                                    </children>
                                </VBox>

                                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                    <children>
                                        <Button mnemonicParsing="false" prefHeight="25.0" prefWidth="106.0" styleClass="cancel-button" text="Cancel" />
                                        <Button mnemonicParsing="false" prefHeight="25.0" prefWidth="145.0" styleClass="next-button" text="Next" />
                                    </children>
                                </HBox>

                            </children>
                        </VBox>
                    </content>
                </ScrollPane>

            </children>
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
        </VBox>
    </center>
</BorderPane>
