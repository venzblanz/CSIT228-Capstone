                        <!-- Calendar panel -->
                        <VBox prefWidth="330.0" spacing="0.0" styleClass="calendar-panel">
                            <children>

                                <!-- Month navigation -->
                                <HBox alignment="CENTER" spacing="10.0" styleClass="calendar-nav">
                                    <children>
                                        <Button fx:id="prevMonthButton" mnemonicParsing="false" styleClass="cal-arrow-button" text="⮜">
                                 <font>
                                    <Font size="18.0" />
                                 </font></Button>
                                        <Label fx:id="monthYearLabel" alignment="CENTER" maxWidth="1.7976931348623157E308" text="April 2026" HBox.hgrow="ALWAYS">
                                            <font><Font name="System Bold" size="13.0" /></font>
                                        </Label>
                                        <Button fx:id="nextMonthButton" mnemonicParsing="false" styleClass="cal-arrow-button" text="⮞">
                                 <font>
                                    <Font size="18.0" />
                                 </font></Button>
                                    </children>
