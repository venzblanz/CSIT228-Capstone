                                        <Label alignment="CENTER" maxWidth="1.7976931348623157E308" styleClass="cal-day-label" text="Th" GridPane.columnIndex="4" GridPane.rowIndex="0" />
                                        <Label alignment="CENTER" maxWidth="1.7976931348623157E308" styleClass="cal-day-label" text="Fr" GridPane.columnIndex="5" GridPane.rowIndex="0" />
                                        <Label alignment="CENTER" maxWidth="1.7976931348623157E308" styleClass="cal-day-label" text="Sa" GridPane.columnIndex="6" GridPane.rowIndex="0" />
                                    </children>
                                    <padding><Insets left="10.0" right="10.0" top="10.0" /></padding>
                                </GridPane>

                                <!-- Calendar day cells (populated by controller) -->
                                <GridPane fx:id="calendarGrid" hgap="8.0" styleClass="cal-days-panel" vgap="8.0" VBox.vgrow="ALWAYS">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
                                    </columnConstraints>
                                    <padding><Insets bottom="20.0" left="10.0" right="10.0" top="4.0" /></padding>
                                </GridPane>
                        <Region prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS" />

                                <!-- Previous / Confirm buttons -->
                                <HBox spacing="8.0">
                                    <children>
                                        <Button fx:id="previousButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="previous-button" text="Previous" HBox.hgrow="ALWAYS" />
                                        <Button fx:id="confirmButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="confirm-button" text="Confirm" HBox.hgrow="ALWAYS" />
