                                <GridPane hgap="2.0" styleClass="day-panel" vgap="2.0">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints minHeight="20.0" vgrow="SOMETIMES" />
                                    </rowConstraints>
                                    <children>
                                        <Label alignment="CENTER" maxWidth="1.7976931348623157E308" styleClass="cal-day-label" text="Su" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                        <Label alignment="CENTER" maxWidth="1.7976931348623157E308" styleClass="cal-day-label" text="Mo" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                        <Label alignment="CENTER" maxWidth="1.7976931348623157E308" styleClass="cal-day-label" text="Tu" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                                        <Label alignment="CENTER" maxWidth="1.7976931348623157E308" styleClass="cal-day-label" text="We" GridPane.columnIndex="3" GridPane.rowIndex="0">
