                                                                    </children>
                                                                </HBox>
                                                            </children>
                                                            <padding><Insets bottom="20.0" left="30.0" right="30.0" top="20.0" /></padding>
                                                        </VBox>
                                                    </children>
                                                    <padding><Insets bottom="4.0" left="10.0" right="10.0" top="4.0" /></padding>
                                                </HBox>

                                                <!-- 10:00 AM — Service 2 -->
