                                    </HBox>
                                    <HBox alignment="TOP_LEFT" layoutX="10.0" layoutY="670.0" spacing="8.0" styleClass="time-row">
                                       <children>
                                          <Label minWidth="55.0" styleClass="time-label" text="4:00 PM" />
                                          <VBox styleClass="slot-card" HBox.hgrow="ALWAYS">
                                             <children>
                                                <Label styleClass="slot-name" text="Service 8">
                                                   <font>
                                                      <Font name="System Bold" size="20.0" />
                                                   </font>
                                                </Label>
                                                <HBox alignment="CENTER_LEFT" spacing="4.0">
                                                   <children>
                                                      <ImageView fitHeight="9.0" fitWidth="9.0" pickOnBounds="true" preserveRatio="true">
                                                         <image>
                                                            <Image url="@../../../../images/maps-and-flags.png" />
                                                         </image>
                                                      </ImageView>
                                                      <Label styleClass="slot-location" text="Location 8" />
                                                   </children>
                                                </HBox>
                                             </children>
