                                       </children>
                                       <padding>
                                          <Insets bottom="4.0" left="10.0" right="10.0" top="4.0" />
                                       </padding>
                                    </HBox>
                                    <HBox alignment="TOP_LEFT" layoutX="10.0" layoutY="575.0" spacing="8.0" styleClass="time-row">
                                       <children>
                                          <Label minWidth="55.0" styleClass="time-label" text="3:00 PM" />
                                          <VBox styleClass="slot-card" HBox.hgrow="ALWAYS">
                                             <children>
                                                <Label styleClass="slot-name" text="Service 7">
                                                   <font>
                                                      <Font name="System Bold" size="20.0" />
